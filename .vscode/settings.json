{
  "editor.defaultFormatter": "xaver.clang-format",

  "files.associations": {
    "*.ino": "cpp"
  },

  "[cpp]": {
    "editor.formatOnSave": true
  },

  "clangd.arguments": [
    "--background-index",
    "--compile-commands-dir=."
  ],

  "C_Cpp.intelliSenseEngine": "disabled",
  "C_Cpp.autocomplete": "disabled",
  "C_Cpp.errorSquiggles": "disabled"
}
